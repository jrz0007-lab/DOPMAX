# Variables de entorno para DOPMAX Backend

# URL de conexión a PostgreSQL (Render proporciona esta automáticamente)
# Ejemplo: postgresql://user:password@hostname:5432/database
DATABASE_URL=postgresql://usuario:contrasena@localhost:5432/dopmax_db

# Puerto del servidor (Render usa el puerto 3000 por defecto)
PORT=3000

# Entorno (development o production)
NODE_ENV=development
